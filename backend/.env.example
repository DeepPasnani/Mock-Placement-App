# ============================================================
# PlacementPro Backend Environment Variables
# Copy this file to .env and fill in all values
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# ── PostgreSQL Database ───────────────────────────────────────
# Option A: Full connection string (Supabase, Railway, Neon, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/placementpro?sslmode=require

# Option B: Individual fields (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=placementpro
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# ── Redis ─────────────────────────────────────────────────────
# Upstash Redis (free tier works for 1000 students)
# Get from: https://console.upstash.com
REDIS_URL=redis://default:YOUR_UPSTASH_PASSWORD@YOUR_UPSTASH_HOST.upstash.io:6379
# OR for local Redis:
# REDIS_URL=redis://localhost:6379

# ── JWT Auth ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_HEX_STRING

# ── Google OAuth ──────────────────────────────────────────────
# Steps:
# 1. Go to https://console.cloud.google.com
# 2. Create a new project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add Authorized JavaScript origins: http://localhost:5173 AND your production domain
# 5. Add Authorized redirect URIs: http://localhost:5173/auth/google/callback
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ── Cloudinary (Image Uploads) ────────────────────────────────
# Steps:
# 1. Sign up free at https://cloudinary.com
# 2. Go to Dashboard → copy Cloud Name, API Key, API Secret
# Free tier: 25 GB storage, 25 GB bandwidth/month (plenty for images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Judge0 (Code Execution) ───────────────────────────────────
# Option A: RapidAPI (easiest, free 50 req/day, paid for more)
# 1. Go to https://rapidapi.com/judge0-official/api/judge0-ce
# 2. Subscribe to Basic (free) plan
# 3. Copy your RapidAPI key
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=YOUR_RAPIDAPI_KEY
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# Option B: Self-hosted Judge0 (unlimited, requires Docker)
# Follow: https://github.com/judge0/judge0/blob/master/CHANGELOG.md
# JUDGE0_API_URL=http://localhost:2358

# ── Email (Optional: for notifications) ──────────────────────
# Use Gmail App Password or SendGrid
# Gmail: https://myaccount.google.com → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_college_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=PlacementPro <noreply@yourcollege.edu>
