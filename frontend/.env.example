# ============================================================
# PlacementPro Frontend Environment Variables
# Copy this to .env and fill in values
# ============================================================

# Backend API URL
VITE_API_URL=http://localhost:5000/api

# WebSocket URL (same server, different protocol)
VITE_WS_URL=ws://localhost:5000/ws

# Google OAuth Client ID (same as backend)
# Get from https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# App name (shown in UI)
VITE_APP_NAME=PlacementPro

# College name (shown in header/footer)
VITE_COLLEGE_NAME=Your College Name
